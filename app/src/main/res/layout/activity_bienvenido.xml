<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#D9D9D9">

    <ImageView
        android:id="@+id/imageViewLogoBienvenido"
        android:layout_width="194dp"
        android:layout_height="199dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/logo"
      />
0
    <TextView
        android:id="@+id/textViewTituloBienvenido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Telemundo"
        android:textColor="#F26A4B"
        android:textSize="40sp"
        android:textStyle="bold"
       />

    <TextView
        android:id="@+id/textViewDescripcionBienvenido"
        android:layout_width="364dp"
        android:layout_height="64dp"
        android:layout_marginTop="56dp"
        android:text="Inicia una nueva aventura con Telemundo y descubre nueva forma de ver el mundo."
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="normal"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonComienza"
        android:layout_width="212dp"
        android:layout_height="62dp"
        android:layout_marginTop="40dp"
        android:text="Comienza"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:backgroundTint="#F26A4B"
        app:cornerRadius="12dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/textViewRegistrate"
        android:layout_width="100dp"
        android:layout_height="27dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="164dp"
        android:text="Registrate"
        android:textColor="#F26A4B"
        android:textSize="16sp" />

</LinearLayout>