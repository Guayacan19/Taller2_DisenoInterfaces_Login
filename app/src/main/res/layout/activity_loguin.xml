<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D9D9D9"
    android:padding="24dp"
    android:gravity="top|center_horizontal">

    <!-- Logo + Nombre -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imageLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo" />

        <TextView
            android:id="@+id/textNombreApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Telemundo"
            android:textColor="#F26A4B"
            android:textSize="30sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/textSubtitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="La aventura está por iniciar,\npor favor inicia sesión"
        android:textSize="18sp"
        android:textStyle="italic" />

    <!-- Usuario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iconUser"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/usser" />

        <EditText
            android:id="@+id/editUsuario"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_campo"
            android:hint="Usuario"
            android:paddingStart="16dp" />

    </LinearLayout>

    <!-- Contraseña -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iconPassword"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/password" />

        <EditText
            android:id="@+id/editContrasena"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_campo"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:paddingStart="16dp" />

    </LinearLayout>

    <!-- Botón Ingresar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIngresar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:text="Ingresar"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#F26A4B"
        app:cornerRadius="30dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp"/>


    <!-- Recuperar contraseña -->
    <TextView
        android:id="@+id/txtRecuperarContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Recupera Tu contraseña"
        android:textSize="14sp" />

    <!-- Botón Google -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogle"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="30dp"
        android:text="Ingresa con Google"
        android:textColor="#000000"
        android:textSize="18sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:strokeColor="#F26A4B"
        app:strokeWidth="2dp"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@null" />

    <!-- Registrarse -->
    <TextView
        android:id="@+id/txtRegistrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/registro_texto"
        android:textSize="14sp"
        />


</LinearLayout>