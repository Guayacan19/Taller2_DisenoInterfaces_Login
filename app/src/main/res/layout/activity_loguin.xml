<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9">


    <ImageView
        android:id="@+id/imageLogo"
        android:layout_width="103dp"
        android:layout_height="107dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textNombreApp"
        android:layout_width="169dp"
        android:layout_height="48dp"
        android:layout_marginStart="28dp"
        android:text="Telemundo"
        android:textColor="#F26A4B"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imageLogo"
        app:layout_constraintStart_toEndOf="@id/imageLogo"
        app:layout_constraintTop_toTopOf="@id/imageLogo"
        app:layout_constraintVertical_bias="0.553" />

    <TextView
        android:id="@+id/textSubtitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="La aventura está por iniciar,\npor favor inicia sesión"
        android:textSize="20sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/imageLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Icono Usuario -->

    <!-- EditText Usuario -->
    <ImageView
        android:id="@+id/iconUser"
        android:layout_width="59dp"
        android:layout_height="49dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/usser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSubtitulo" />

    <EditText
        android:id="@+id/editUsuario"
        android:layout_width="307dp"
        android:layout_height="47dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_campo"
        android:hint="Usuario"
        android:paddingStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/iconUser"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.03"
        app:layout_constraintStart_toEndOf="@id/iconUser"
        app:layout_constraintTop_toTopOf="@id/iconUser"
        app:layout_constraintVertical_bias="1.0" />

    <!-- Icono Usuario -->

    <!-- EditText Usuario -->
    <ImageView
        android:id="@+id/iconPassword"
        android:layout_width="59dp"
        android:layout_height="49dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/usser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSubtitulo" />

    <EditText
        android:id="@+id/editPassword"
        android:layout_width="307dp"
        android:layout_height="47dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_campo"
        android:hint="Usuario"
        android:paddingStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/iconUser"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.03"
        app:layout_constraintStart_toEndOf="@id/iconUser"
        app:layout_constraintTop_toTopOf="@id/iconUser"
        app:layout_constraintVertical_bias="1.0" />

    <!-- Icono Contraseña -->

    <!-- EditText Contraseña -->

    <ImageView
        android:id="@+id/iconPassword"
        android:layout_width="59dp"
        android:layout_height="49dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconUser" />

    <EditText
        android:id="@+id/editContrasena"
        android:layout_width="304dp"
        android:layout_height="47dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_campo"
        android:hint="Contraseña"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/iconPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/iconPassword"
        app:layout_constraintTop_toTopOf="@id/iconPassword"
        app:layout_constraintVertical_bias="1.0" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnIngresar"
        android:layout_width="273dp"
        android:layout_height="65dp"
        android:layout_marginTop="40dp"
        android:text="Ingresar"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"

        app:backgroundTint="#F26A4B"
        app:cornerRadius="25dp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.625"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconPassword"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/txtRecuperarContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Recupera Tu contraseña"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.528"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnIngresar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogle"
        android:layout_width="306dp"
        android:layout_height="51dp"
        android:layout_marginTop="36dp"
        android:text="Ingresa con Google"
        android:textColor="#000000"
        android:textSize="20sp"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="25dp"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:iconPadding="3dp"
        app:iconSize="40dp"
        app:iconTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.676"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtRecuperarContrasena"
        app:strokeColor="#F26A4B"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/txtRegistrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/registro_texto"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.569"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnGoogle" />

</androidx.constraintlayout.widget.ConstraintLayout>